#!/bin/sh

case "$1" in
  html )
    xdg-open "https://developer.mozilla.org/search?topic=api&topic=html&q=$2"
    ;;
  css )
    xdg-open "https://developer.mozilla.org/search?topic=api&topic=css&q=$2"
    ;;
  javascript )
    xdg-open "https://developer.mozilla.org/search?topic=api&topic=js&q=$2"
    ;;
  python )
    xdg-open "https://docs.python.org/2/search.html?q=$2"
    ;;
  * )
    xdg-open "https://www.google.com/search?&q=$2"
    ;;
esac
