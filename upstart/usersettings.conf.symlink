# vim: set filetype=upstart:
start on desktop-start
stop on desktop-end

script
  # ensure X will load my favourite fonts
  xset fp+ ~/.fonts/dina
  xset fp+ ~/.fonts/envypn
  # keyboard better delay and repeat values
  xset r rate 300 50
  # override gnome-settings to get our values
  gsettings set org.gnome.settings-daemon.peripherals.keyboard delay 300
  # this is equal to xset r rate XXX 50
  gsettings set org.gnome.settings-daemon.peripherals.keyboard repeat-interval 20
end script
